# Copy this file to `.env.pahf` and fill the values below.

# Required for any PAHF run that calls an OpenAI-compatible API.
PAHF_OPENAI_API_KEY=

# Optional if you use the default OpenAI endpoint. Required for proxy / third-party compatible endpoints.
PAHF_OPENAI_BASE_URL=

# Optional model defaults.
PAHF_AGENT_MODEL=gpt-4o-mini
PAHF_HUMAN_MODEL=gpt-4o-mini

# Optional runtime knobs.
PAHF_OPENAI_TIMEOUT=180
PAHF_OPENAI_MAX_RETRIES=5

# Optional execution mode hint for cloud docs/scripts.
# `native` = PAHF baseline / no-memory runtime
# `full_memory` = local embedding model enabled
PAHF_RUN_MODE=native
