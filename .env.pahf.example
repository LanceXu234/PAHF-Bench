# Copy this file to `.env.pahf` and fill the values below.

# Required for any PAHF run that calls an OpenAI-compatible API.
PAHF_OPENAI_API_KEY=

# Optional if you use the default OpenAI endpoint. Required for proxy / third-party compatible endpoints.
PAHF_OPENAI_BASE_URL=

# Optional model defaults.
PAHF_AGENT_MODEL=gpt-4o-mini
PAHF_HUMAN_MODEL=gpt-4o-mini

# Optional runtime knobs.
PAHF_OPENAI_TIMEOUT=180
PAHF_OPENAI_MAX_RETRIES=5

# Optional execution mode hint for cloud docs/scripts.
# `native` = PAHF baseline / no-memory runtime
# `full_memory` = PAHF local embedding memory enabled
# `vitabench_bridge` = native VitaBench runner with PAHF memory backend
PAHF_RUN_MODE=native

# --------------------------------------------------------------------
# Native VitaBench bridge configuration
# --------------------------------------------------------------------

# Official VitaBench checkout used by the bridge bootstrap.
PAHF_VITABENCH_ROOT=external/vitabench-2.0
PAHF_VITABENCH_COMMIT=0c481ae1f97b973fe0fa0d30e78ab463c4d59193

# Optional model overrides for VitaBench's three LLM roles.
# If left empty, the runner falls back to PAHF_AGENT_MODEL / PAHF_HUMAN_MODEL.
PAHF_VITA_AGENT_LLM=
PAHF_VITA_USER_LLM=
PAHF_VITA_EVALUATOR_LLM=

# Default fixed task slice shipped in this repository.
PAHF_VITA_TASK_FILE=data/vitabench/dynamic_delivery_28.tasks.json

# Evaluation knobs for the VitaBench bridge.
PAHF_VITA_NUM_TRIALS=4
PAHF_VITA_MAX_STEPS=300
PAHF_VITA_MAX_ERRORS=10
PAHF_VITA_MAX_CONCURRENCY=2
PAHF_VITA_SEED=300
PAHF_VITA_LANGUAGE=chinese
PAHF_VITA_EVALUATION_TYPE=trajectory
PAHF_VITA_MEMORY_BACKEND=sql
PAHF_VITA_ENABLE_OUTCOME_REWARD=0
PAHF_VITA_DISABLE_LLM_EXTRACTION=0
PAHF_VITA_DISABLE_LLM_QUESTIONS=0

# Optional smoke / output knobs.
PAHF_VITA_LIMIT_TASKS=
PAHF_VITA_RUN_NAME=
PAHF_VITA_RUN_ROOT=runs/vitabench_pahf
